#  Smart System — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores

# Banco de Dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Segredo do JWT (mínimo 32 caracteres aleatórios)
JWT_SECRET=troque_por_uma_string_aleatoria_e_longa

# URL do frontend (sem barra no final)
# Múltiplas origens separadas por vírgula
FRONT_URL=http://127.0.0.1:5500

# Serviço de envio de e-mails (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_USER=noreply@seudominio.com.br

# Ambiente (development | production | test)
NODE_ENV=development

# Porta do servidor (opcional — padrão 3000)
PORT=3000
